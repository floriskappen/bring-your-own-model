---
// Full-bleed ambient layer, shared by every page. Both effects are generated
// at build time (no client JS) so they stay CSP-safe under script-src 'none':
//   1. warm bloom — slow-drifting radial gradients (slate-mapped); always
//      visible full-bleed.
//   2. breathing grid — hairline cells whose opacity pulses on desynced clocks
//      (ported from the zoo's atmosphere.grid.breathing). Masked out behind the
//      centred content column and faded in gradually toward the page edges.
// The firefly motes belong to the masthead, not the page, so they live in
// Fireflies.astro (scoped + masked around the title), not here.

const r3 = (n: number): string => n.toFixed(3);
const r2 = (n: number): string => n.toFixed(2);
const lcg = (n: number): number => ((n * 9301 + 49297) % 233280) / 233280;

// ── breathing grid ──────────────────────────────────────────────────
const COLS = 16;
const ROWS = 10;
const cells = Array.from({ length: COLS * ROWS }, (_, i) => {
  const a = r3(0.04 + lcg(i * 9301 + 49297) * 0.05); // low  0.040–0.090
  const b = r3(0.09 + lcg(i * 1597 + 51749) * 0.06); // high 0.090–0.150
  const d = r2(7 + lcg(i * 7919 + 12553) * 9);       // 7–16s
  const dl = r2(-lcg(i * 9301 + 49297) * 12);        // desync offset
  return { a, b, d, dl };
});
---

<div class="atmosphere" aria-hidden="true">
  <div class="bloom">
    <i class="b1"></i>
    <i class="b2"></i>
    <i class="b3"></i>
  </div>

  <div class="grid" style={`--cols:${COLS};--rows:${ROWS}`}>
    {cells.map((c) => (
      <i style={`--a:${c.a};--b:${c.b};--d:${c.d}s;--dl:${c.dl}s`}></i>
    ))}
  </div>
</div>
