---
import Base from '../layouts/Base.astro';
import jsyaml from 'js-yaml';
import { readFileSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import { dirname, join } from 'node:path';

const here = dirname(fileURLToPath(import.meta.url));
const registryPath = join(here, '..', '..', 'registry', 'registry.yaml');
const registry = jsyaml.load(readFileSync(registryPath, 'utf-8'));
const apps = registry.apps;
---

<Base title="registry" path="/registry" description="apps that follow the byom pattern. worth maintaining even at n=1.">
  <header class="masthead">
    <h1 class="big">registry</h1>
    <p class="sub">apps that follow the pattern. worth maintaining even with one entry; anyone else adopting it is a bonus.</p>
  </header>

  <section>
    <div class="sec-head">
      <span class="fig">01</span>
      <h2>participating apps</h2>
      <span class="sec-note">{apps.length} app{apps.length !== 1 ? 's' : ''}</span>
    </div>
    <div class="prose">
      <p>listing an app says it follows the pattern and the invariants and that a <code>BYOM-INTEGRATION.md</code> exists — it is not a security audit. the badge does not guarantee safety, and neither does a registry entry.</p>
    </div>
    <div class="registry-list" style="margin-top: var(--space-lg);">
      {apps.map((app) => (
        <div class="card">
          <h3 class="card-title">{app.name}</h3>
          <p class="card-body">{app.description}</p>
          <a href={app.url} class="card-url lnk" rel="noopener">{app.url}</a>
          <div class="card-meta">
            <span class="pill pill-quiet"><span class="pdot"></span>{app.pinned_constitution_version}</span>
            {app.badge_variant && <span class="pill pill-quiet"><span class="pdot"></span>{app.badge_variant}</span>}
          </div>
          <div class="card-features">
            {app.model_powered_features.map((f) => (
              <div class="feature-row">
                <span class="feature-name">{f.name}</span>
                <span class="feature-desc">{f.description}</span>
                <span class="pill" style={`color: ${f.category === 'frontier' ? 'var(--color-accent-base)' : 'var(--color-text-quiet)'}; border-color: ${f.category === 'frontier' ? 'var(--color-accent-base)' : 'var(--color-border-quiet)'};`}>
                  <span class="pdot"></span>{f.category}
                </span>
              </div>
            ))}
          </div>
          <div style="margin-top: var(--space-sm); display: flex; gap: var(--space-sm); flex-wrap: wrap;">
            <a href={app.integration_doc_url} class="lnk" rel="noopener">integration doc</a>
            <a href={app.source_url} class="lnk" rel="noopener">source</a>
          </div>
          {app.notes && <p style="font: var(--typography-body-sm); color: var(--color-text-soft); margin: var(--space-xs) 0 0;">{app.notes}</p>}
        </div>
      ))}
    </div>
  </section>

  <section>
    <div class="sec-head">
      <span class="fig">02</span>
      <h2>add your app</h2>
    </div>
    <div class="prose">
      <p>submissions are pr-based. add your entry to <code>registry.yaml</code>, validate it against the schema, and open a pr. the validator runs in ci and will block the merge on any violation.</p>
      <p style="margin-top: var(--space-md);">
        see <a href="https://github.com/floriskappen/bring-your-own-model/blob/main/website/registry/README.md" class="lnk">the registry readme</a> for the field reference and submission process.
      </p>
    </div>
  </section>

  <div class="divider" aria-hidden="true">
    <svg class="seed" viewBox="0 0 42 42">
      <circle cx="21" cy="21" r="2.5" />
      <circle cx="14" cy="16" r="2" />
      <circle cx="28" cy="16" r="2" />
      <circle cx="16" cy="28" r="2" />
      <circle cx="26" cy="28" r="2" />
      <circle cx="21" cy="12" r="1.5" />
      <circle cx="21" cy="30" r="1.5" />
      <circle cx="12" cy="22" r="1.5" />
      <circle cx="30" cy="22" r="1.5" />
    </svg>
  </div>
</Base>
